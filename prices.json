/ fetch-prices.js — Viking Invest 15-min price fetcher
// Runs inside GitHub Actions. Reads TD_API_KEY from env.
// Outputs prices.json with { updated, prices: { eurusd: {price, chgPct}, ... } }

const fs = require('fs');
const https = require('https');

const API_KEY = process.env.TD_API_KEY;
if(!API_KEY){ console.error('Missing TD_API_KEY env var'); process.exit(1); }

// Pair map: dashboard key → Twelve Data symbol
const PAIRS = {
  eurusd:'EUR/USD', gbpusd:'GBP/USD', usdjpy:'USD/JPY', usdcad:'USD/CAD',
  usdchf:'USD/CHF', nzdusd:'NZD/USD', audusd:'AUD/USD', usdsgd:'USD/SGD',
  cadjpy:'CAD/JPY', eurjpy:'EUR/JPY', gbpjpy:'GBP/JPY', eurnzd:'EUR/NZD',
  gbpaud:'GBP/AUD', euraud:'EUR/AUD', gbpdkk:'GBP/DKK', audnzd:'AUD/NZD',
  eurgbp:'EUR/GBP', eurchf:'EUR/CHF', audchf:'AUD/CHF', gbpchf:'GBP/CHF',
  xauusd:'XAU/USD', xagusd:'XAG/USD', btcusd:'BTC/USD', suiusd:'SUI/USD'
  // Note: WTI OIL and DE40/DAX are on separate endpoints — see docs
};

function getJSON(url){
  return new Promise((resolve, reject) => {
    https.get(url, res => {
      let data = '';
      res.on('data', chunk => data += chunk);
      res.on('end', () => {
        try { resolve(JSON.parse(data)); }
        catch(e){ reject(e); }
      });
    }).on('error', reject);
  });
}

(async () => {
  const symbols = Object.values(PAIRS).join(',');
  const url = `https://api.twelvedata.com/time_series?symbol=${encodeURIComponent(symbols)}&interval=15min&outputsize=2&apikey=${API_KEY}`;
  const resp = await getJSON(url);

  const out = { updated: new Date().toISOString(), prices: {} };
  Object.entries(PAIRS).forEach(([key, sym]) => {
    const row = resp[sym] || resp;
    if(!row || !row.values || !row.values.length){
      console.warn('No data for', sym); return;
    }
    const latest = parseFloat(row.values[0].close);
    const prev   = row.values[1] ? parseFloat(row.values[1].close) : latest;
    const chgPct = prev ? ((latest - prev) / prev) * 100 : 0;
    out.prices[key] = { price: latest, chgPct: +chgPct.toFixed(3) };
  });

  fs.writeFileSync('prices.json', JSON.stringify(out, null, 2));
  console.log('Wrote prices.json with', Object.keys(out.prices).length, 'pairs');
})();
